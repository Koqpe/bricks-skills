  "source": "bricksCopiedElements",
  "sourceUrl": "https://github.com/wpgaurav/bricks-skills",
  "version": "2.3.6",
  "globalClasses": [
    {
      "id": "ftcard",
      "name": "feature-card",
      "settings": {
        "_background": { "color": { "hex": "#ffffff" } },
        "_border": {
          "width": { "top": "1px", "right": "1px", "bottom": "1px", "left": "1px" },
          "style": "solid",
          "color": { "rgb": "rgba(15, 23, 42, 0.08)" },
          "radius": { "top": "16px", "right": "16px", "bottom": "16px", "left": "16px" }
        },
        "_padding": { "top": "32px", "right": "32px", "bottom": "32px", "left": "32px" },
        "_rowGap": "16px",
        "_cssTransition": "transform 0.25s ease, box-shadow 0.25s ease",
        "_transform:hover": { "translateY": "-4" },
        "_boxShadow:hover": {
          "values": { "offsetX": "0", "offsetY": "12", "blur": "32", "spread": "-8" },
          "color": { "rgb": "rgba(15, 23, 42, 0.18)" }
        }
      }
    },
    {
      "id": "fticon",
      "name": "feature-icon",
      "settings": {
        "_background": { "color": { "rgb": "rgba(37, 99, 235, 0.1)" } },
        "_padding": { "top": "12px", "right": "12px", "bottom": "12px", "left": "12px" },
        "_border": { "radius": { "top": "12px", "right": "12px", "bottom": "12px", "left": "12px" } }
      }
    }
  ],
  "globalElements": []
}
