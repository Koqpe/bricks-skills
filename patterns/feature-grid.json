          { "id": "ftrv03", "trigger": "enterView", "action": "startAnimation", "animationType": "fadeInUp", "animationDuration": "0.5s", "animationDelay": "0.2s", "target": "self", "runOnce": true }
        ]
      }
    },
    {
      "id": "fti003",
      "name": "icon",
      "parent": "ftcd03",
      "children": [],
      "settings": {
        "icon": { "library": "themify", "icon": "ti-shield" },
        "iconSize": "24px",
        "iconColor": { "hex": "#2563eb" },
        "_cssGlobalClasses": ["fticon"]
      }
    },
    {
      "id": "fth003",
      "name": "heading",
      "parent": "ftcd03",
      "children": [],
      "settings": {
        "text": "Secure by default",
        "tag": "h3",
        "_typography": { "font-size": "1.25rem", "font-weight": "600" }
      }
    },
    {
      "id": "ftt003",
      "name": "text-basic",
      "parent": "ftcd03",
      "children": [],
      "settings": {
        "text": "Sanitized output, capability-gated code execution, and battle-tested form handling.",
        "tag": "p",
        "_typography": { "color": { "hex": "#64748b" }, "line-height": "1.6" }
      }
