      "parent": "ftcd02",
      "children": [],
      "settings": {
        "text": "Real CSS grid and flexbox controls with per-breakpoint overrides — no rigid column systems.",
        "tag": "p",
        "_typography": { "color": { "hex": "#64748b" }, "line-height": "1.6" }
      }
    },
    {
      "id": "ftcd03",
      "name": "block",
      "parent": "ftgrd1",
      "children": ["fti003", "fth003", "ftt003"],
