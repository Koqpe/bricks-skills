{
  "content": [
    {
      "id": "ftsec1",
      "name": "section",
      "parent": 0,
      "children": ["ftcon1"],
      "label": "Features",
      "settings": {
        "tag": "section",
        "_padding": { "top": "clamp(4rem, 8vw, 7rem)", "bottom": "clamp(4rem, 8vw, 7rem)" }
      }
    },
    {
      "id": "ftcon1",
      "name": "container",
      "parent": "ftsec1",
      "children": ["fthdr1", "ftgrd1"],
      "settings": { "_rowGap": "56px" }
    },
    {
      "id": "fthdr1",
      "name": "block",
      "parent": "ftcon1",
      "children": ["fteyb1", "ftttl1", "ftsub1"],
      "label": "Section Header",
      "settings": {
        "_rowGap": "12px",
        "_alignItems": "center",
        "_widthMax": "640px",
        "_margin": { "left": "auto", "right": "auto" }
      }
    },
    {
      "id": "fteyb1",
      "name": "text-basic",
      "parent": "fthdr1",
      "children": [],
      "label": "Eyebrow",
      "settings": {
        "text": "FEATURES",
        "tag": "span",
        "_typography": {
          "font-size": "0.8125rem",
          "font-weight": "600",
          "letter-spacing": "0.1em",
          "text-transform": "uppercase",
          "color": { "hex": "#2563eb" },
          "text-align": "center"
        }
      }
    },
    {
      "id": "ftttl1",
      "name": "heading",
      "parent": "fthdr1",
      "children": [],
      "settings": {
        "text": "Everything you need to launch",
        "tag": "h2",
        "_typography": { "text-align": "center", "font-size": "clamp(1.875rem, 4vw, 2.5rem)", "font-weight": "700", "line-height": "1.15" }
      }
    },
    {
      "id": "ftsub1",
      "name": "text-basic",
      "parent": "fthdr1",
      "children": [],
      "settings": {
        "text": "Powerful building blocks that work together, so you can focus on the parts that make your site unique.",
        "tag": "p",
        "_typography": { "text-align": "center", "color": { "hex": "#64748b" }, "line-height": "1.6" }
      }
    },
    {
      "id": "ftgrd1",
      "name": "div",
      "parent": "ftcon1",
      "children": ["ftcd01", "ftcd02", "ftcd03"],
      "label": "Feature Grid",
      "settings": {
        "_display": "grid",
        "_gridTemplateColumns": "repeat(3, minmax(0, 1fr))",
        "_gridGap": "32px",
        "_gridTemplateColumns:tablet_portrait": "repeat(2, minmax(0, 1fr))",
        "_gridTemplateColumns:mobile_portrait": "1fr"
      }
    },
    {
      "id": "ftcd01",
      "name": "block",
      "parent": "ftgrd1",
      "children": ["fti001", "fth001", "ftt001"],
      "label": "Feature Card",
      "settings": {
        "_cssGlobalClasses": ["ftcard"],
        "_interactions": [
          { "id": "ftrv01", "trigger": "enterView", "action": "startAnimation", "animationType": "fadeInUp", "animationDuration": "0.5s", "target": "self", "runOnce": true }
        ]
      }
    },
    {
      "id": "fti001",
      "name": "icon",
      "parent": "ftcd01",
      "children": [],
      "settings": {
        "icon": { "library": "themify", "icon": "ti-bolt" },
        "iconSize": "24px",
        "iconColor": { "hex": "#2563eb" },
        "_cssGlobalClasses": ["fticon"]
      }
    },
    {
      "id": "fth001",
      "name": "heading",
      "parent": "ftcd01",
      "children": [],
      "settings": {
        "text": "Instant publishing",
        "tag": "h3",
        "_typography": { "font-size": "1.25rem", "font-weight": "600" }
      }
    },
    {
      "id": "ftt001",
      "name": "text-basic",
      "parent": "ftcd01",
      "children": [],
      "settings": {
        "text": "Push changes live in one click with automatic asset regeneration and cache busting.",
        "tag": "p",
        "_typography": { "color": { "hex": "#64748b" }, "line-height": "1.6" }
      }
    },
    {
      "id": "ftcd02",
      "name": "block",
      "parent": "ftgrd1",
      "children": ["fti002", "fth002", "ftt002"],
