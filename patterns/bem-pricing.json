  "globalClasses": [
    {
      "id": "bmpsec",
      "name": "pricing",
      "settings": {
        "_padding": {
          "top": "clamp(4rem, 8vw, 7rem)",
          "bottom": "clamp(4rem, 8vw, 7rem)"
        }
      }
    },
    {
      "id": "bmpinn",
      "name": "pricing__inner",
      "settings": {
        "_rowGap": "56px"
      }
    },
    {
      "id": "bmpttl",
      "name": "pricing__title",
      "settings": {
        "_typography": {
          "text-align": "center",
          "font-size": "clamp(1.875rem, 4vw, 2.5rem)",
          "font-weight": "700"
        }
      }
    },
    {
      "id": "bmpgrd",
      "name": "pricing__grid",
      "settings": {
        "_display": "grid",
        "_gridTemplateColumns": "repeat(3, minmax(0, 1fr))",
        "_gridGap": "32px",
        "_alignItemsGrid": "stretch",
        "_gridTemplateColumns:tablet_portrait": "1fr",
        "_widthMax:tablet_portrait": "480px",
        "_margin:tablet_portrait": {
          "left": "auto",
          "right": "auto"
        }
      }
    },
    {
      "id": "bmplan",
      "name": "plan",
      "settings": {
        "_background": {
          "color": {
            "hex": "#ffffff"
          }
        },
        "_border": {
          "width": {
            "top": "1px",
            "right": "1px",
            "bottom": "1px",
            "left": "1px"
          },
          "style": "solid",
          "color": {
            "rgb": "rgba(15, 23, 42, 0.08)"
          },
          "radius": {
            "top": "16px",
            "right": "16px",
            "bottom": "16px",
            "left": "16px"
          }
        },
        "_padding": {
          "top": "40px",
          "right": "32px",
          "bottom": "40px",
          "left": "32px"
        },
        "_rowGap": "24px",
        "_position": "relative"
      }
    },
    {
      "id": "bmplft",
      "name": "plan--featured",
      "settings": {
        "_border": {
          "width": {
            "top": "2px",
            "right": "2px",
            "bottom": "2px",
            "left": "2px"
          },
          "style": "solid",
          "color": {
            "hex": "#0ea5e9"
          },
          "radius": {
            "top": "16px",
            "right": "16px",
            "bottom": "16px",
            "left": "16px"
          }
        },
        "_boxShadow": {
          "values": {
            "offsetX": "0",
            "offsetY": "16",
            "blur": "40",
            "spread": "-16"
          },
          "color": {
            "rgb": "rgba(14, 165, 233, 0.35)"
          }
        }
      }
    },
    {
      "id": "bmpbdg",
      "name": "plan__badge",
      "settings": {
        "_typography": {
          "font-size": "0.6875rem",
          "font-weight": "700",
          "letter-spacing": "0.08em",
          "color": {
            "hex": "#ffffff"
          }
        },
        "_background": {
          "color": {
            "hex": "#0ea5e9"
          }
        },
        "_padding": {
          "top": "6px",
          "right": "12px",
          "bottom": "6px",
          "left": "12px"
        },
        "_border": {
          "radius": {
            "top": "999px",
            "right": "999px",
            "bottom": "999px",
            "left": "999px"
          }
        },
        "_position": "absolute",
        "_top": "-14px",
        "_left": "50%",
        "_transform": {
          "translateX": "-50%"
        }
      }
    },
    {
      "id": "bmpnam",
      "name": "plan__name",
      "settings": {
        "_typography": {
          "font-size": "1.125rem",
          "font-weight": "600"
        }
      }
    },
    {
      "id": "bmppri",
      "name": "plan__price",
      "settings": {
        "_typography": {
          "font-size": "2.5rem",
          "font-weight": "700",
          "line-height": "1"
        },
        "_cssCustom": ".plan__price .plan__period { font-size: 1rem; font-weight: 400; color: #64748b; }"
      }
    },
    {
      "id": "bmpfea",
      "name": "plan__features",
      "settings": {
        "_flexGrow": "1",
        "_typography": {
          "color": {
            "hex": "#334155"
          },
          "font-size": "0.9375rem"
        },
        "_cssCustom": ".plan__features .icon-list-icon { color: #16a34a; }"
      }
    },
    {
      "id": "bmpcta",
      "name": "plan__cta",
      "settings": {
        "_width": "100%",
        "_typography": {
          "font-weight": "600",
          "text-align": "center",
          "color": {
            "hex": "#0369a1"
          }
        },
        "_background": {
          "color": {
            "rgb": "rgba(14, 165, 233, 0.08)"
          }
        },
        "_border": {
          "width": {
            "top": "1px",
            "right": "1px",
            "bottom": "1px",
            "left": "1px"
          },
          "style": "solid",
          "color": {
            "rgb": "rgba(14, 165, 233, 0.3)"
          },
          "radius": {
            "top": "10px",
            "right": "10px",
            "bottom": "10px",
            "left": "10px"
          }
        },
        "_cssTransition": "background-color 0.2s ease",
        "_background:hover": {
          "color": {
            "rgb": "rgba(14, 165, 233, 0.16)"
          }
        }
      }
    },
    {
      "id": "bmpcts",
      "name": "plan__cta--solid",
      "settings": {
        "_background": {
          "color": {
            "hex": "#0ea5e9"
          }
        },
        "_typography": {
          "color": {
            "hex": "#ffffff"
          },
          "font-weight": "600",
          "text-align": "center"
        },
        "_border": {
          "radius": {
            "top": "10px",
            "right": "10px",
            "bottom": "10px",
            "left": "10px"
          }
        },
        "_background:hover": {
          "color": {
            "hex": "#0284c7"
          }
        }
      }
    }
  ],
  "globalElements": []
}