  "source": "bricksCopiedElements",
  "sourceUrl": "https://github.com/wpgaurav/bricks-skills",
  "version": "2.3.6",
  "globalClasses": [
    {
      "id": "bmcsec",
      "name": "cards",
      "settings": {
        "_padding": {
          "top": "clamp(4rem, 8vw, 7rem)",
          "bottom": "clamp(4rem, 8vw, 7rem)"
        },
        "_background": {
          "color": {
            "hex": "#f8fafc"
          }
        }
      }
    },
    {
      "id": "bmcinn",
      "name": "cards__inner",
      "settings": {
        "_rowGap": "56px"
      }
    },
    {
      "id": "bmchdr",
      "name": "cards__header",
      "settings": {
        "_rowGap": "12px",
        "_alignItems": "center",
        "_widthMax": "640px",
        "_margin": {
          "left": "auto",
          "right": "auto"
        }
      }
    },
    {
      "id": "bmcttl",
      "name": "cards__title",
      "settings": {
        "_typography": {
          "text-align": "center",
          "font-size": "clamp(1.875rem, 4vw, 2.5rem)",
          "font-weight": "700"
        }
      }
    },
    {
      "id": "bmcsub",
      "name": "cards__subtitle",
      "settings": {
        "_typography": {
          "text-align": "center",
          "color": {
            "hex": "#64748b"
          },
          "line-height": "1.6"
        }
      }
    },
    {
      "id": "bmcgrd",
      "name": "cards__grid",
      "settings": {
        "_display": "grid",
        "_gridTemplateColumns": "repeat(3, minmax(0, 1fr))",
        "_gridGap": "32px",
        "_alignItemsGrid": "stretch",
        "_gridTemplateColumns:tablet_portrait": "1fr",
        "_widthMax:tablet_portrait": "480px",
        "_margin:tablet_portrait": {
          "left": "auto",
          "right": "auto"
        }
      }
    },
    {
      "id": "bmcard",
      "name": "card",
      "settings": {
        "_background": {
          "color": {
            "hex": "#ffffff"
          }
        },
        "_border": {
          "width": {
            "top": "1px",
            "right": "1px",
            "bottom": "1px",
            "left": "1px"
          },
          "style": "solid",
          "color": {
            "rgb": "rgba(15, 23, 42, 0.08)"
          },
          "radius": {
            "top": "16px",
            "right": "16px",
            "bottom": "16px",
            "left": "16px"
          }
        },
        "_padding": {
          "top": "32px",
          "right": "32px",
          "bottom": "32px",
          "left": "32px"
        },
        "_rowGap": "16px",
        "_alignItems": "flex-start",
        "_position": "relative",
        "_cssTransition": "transform 0.25s ease, box-shadow 0.25s ease",
        "_transform:hover": {
          "translateY": "-4"
        },
        "_boxShadow:hover": {
          "values": {
            "offsetX": "0",
            "offsetY": "12",
            "blur": "32",
            "spread": "-8"
          },
          "color": {
            "rgb": "rgba(15, 23, 42, 0.16)"
          }
        }
      }
    },
    {
      "id": "bmcftd",
      "name": "card--featured",
      "settings": {
        "_background": {
          "color": {
            "hex": "#0f172a"
          }
        },
        "_border": {
          "width": {
            "top": "1px",
            "right": "1px",
            "bottom": "1px",
            "left": "1px"
          },
          "style": "solid",
          "color": {
            "rgb": "rgba(56, 189, 248, 0.4)"
          },
          "radius": {
            "top": "16px",
            "right": "16px",
            "bottom": "16px",
            "left": "16px"
          }
        },
        "_boxShadow": {
          "values": {
            "offsetX": "0",
            "offsetY": "16",
            "blur": "40",
            "spread": "-12"
          },
          "color": {
            "rgb": "rgba(15, 23, 42, 0.35)"
          }
        },
        "_cssCustom": ".card--featured .card__title { color: #ffffff; }\n.card--featured .card__text { color: rgba(226, 232, 240, 0.75); }"
      }
    },
    {
      "id": "bmcbdg",
      "name": "card__badge",
      "settings": {
        "_typography": {
          "font-size": "0.6875rem",
          "font-weight": "700",
          "letter-spacing": "0.08em",
          "color": {
            "hex": "#0f172a"
          }
        },
        "_background": {
          "color": {
            "hex": "#38bdf8"
          }
        },
        "_padding": {
          "top": "5px",
          "right": "10px",
          "bottom": "5px",
          "left": "10px"
        },
        "_border": {
          "radius": {
            "top": "999px",
            "right": "999px",
            "bottom": "999px",
            "left": "999px"
          }
        },
        "_position": "absolute",
        "_top": "-12px",
        "_right": "24px"
      }
    },
    {
      "id": "bmcico",
      "name": "card__icon",
      "settings": {
        "_typography": {
          "color": {
            "hex": "#0ea5e9"
          }
        },
        "_background": {
          "color": {
            "rgb": "rgba(14, 165, 233, 0.1)"
          }
        },
        "_padding": {
          "top": "12px",
          "right": "12px",
          "bottom": "12px",
          "left": "12px"
        },
        "_border": {
          "radius": {
            "top": "12px",
            "right": "12px",
            "bottom": "12px",
            "left": "12px"
          }
        }
      }
    },
    {
      "id": "bmcdtl",
      "name": "card__title",
      "settings": {
        "_typography": {
          "font-size": "1.25rem",
          "font-weight": "600"
        }
      }
    },
    {
      "id": "bmcdtx",
      "name": "card__text",
      "settings": {
        "_typography": {
          "color": {
            "hex": "#64748b"
          },
          "line-height": "1.6"
        },
        "_flexGrow": "1"
      }
    },
    {
      "id": "bmclnk",
      "name": "card__link",
      "settings": {
        "_typography": {
          "font-weight": "600",
          "font-size": "0.9375rem",
          "color": {
            "hex": "#0ea5e9"
          }
        },
        "_cssTransition": "color 0.2s ease",
        "_typography:hover": {
          "color": {
            "hex": "#0284c7"
          }
        }
      }
    },
    {
      "id": "bmclkf",
      "name": "card__link--inverse",
      "settings": {
        "_typography": {
          "color": {
            "hex": "#38bdf8"
          }
        },
        "_typography:hover": {
          "color": {
            "hex": "#7dd3fc"
          }
        }
      }
    }
  ],
  "globalElements": []
}