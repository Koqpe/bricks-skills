    { "id": "tsqt01", "name": "text", "parent": "tssl01", "children": [],
      "settings": { "text": "<p>“We rebuilt our entire agency site in two days. The JSON-paste workflow with reusable classes is a genuine superpower.”</p>",
        "_typography": { "font-size": "1.125rem", "line-height": "1.6", "color": { "rgb": "rgba(226,232,240,0.95)" } } } },
    { "id": "tsau01", "name": "text-basic", "parent": "tssl01", "children": [],
      "settings": { "text": "Maya R. — Studio Northline", "tag": "p",
        "_typography": { "font-weight": "600", "font-size": "0.9375rem", "color": { "hex": "#93c5fd" } } } },
    { "id": "tssl02", "name": "block", "parent": "tssld1", "children": ["tsqt02", "tsau02"], "label": "Slide",
      "settings": { "_cssGlobalClasses": ["tscard"] } },
    { "id": "tsqt02", "name": "text", "parent": "tssl02", "children": [],
      "settings": { "text": "<p>“Query loops plus ACF turned our documentation hub into a living product. Zero custom PHP.”</p>",
        "_typography": { "font-size": "1.125rem", "line-height": "1.6", "color": { "rgb": "rgba(226,232,240,0.95)" } } } },
    { "id": "tsau02", "name": "text-basic", "parent": "tssl02", "children": [],
      "settings": { "text": "Dev P. — Fieldnotes SaaS", "tag": "p",
        "_typography": { "font-weight": "600", "font-size": "0.9375rem", "color": { "hex": "#93c5fd" } } } },
    { "id": "tssl03", "name": "block", "parent": "tssld1", "children": ["tsqt03", "tsau03"], "label": "Slide",
      "settings": { "_cssGlobalClasses": ["tscard"] } },
    { "id": "tsqt03", "name": "text", "parent": "tssl03", "children": [],
      "settings": { "text": "<p>“Faceted filters that just work — our catalog finally feels like a modern app instead of a blog.”</p>",
        "_typography": { "font-size": "1.125rem", "line-height": "1.6", "color": { "rgb": "rgba(226,232,240,0.95)" } } } },
    { "id": "tsau03", "name": "text-basic", "parent": "tssl03", "children": [],
      "settings": { "text": "Ana K. — Mercado Verde", "tag": "p",
        "_typography": { "font-weight": "600", "font-size": "0.9375rem", "color": { "hex": "#93c5fd" } } } }
